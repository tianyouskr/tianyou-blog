---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';

interface Props {
  post: CollectionEntry<'posts'>;
}
const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const locale = lang === 'zh' ? 'zh-CN' : 'en-US';
const pub = post.data.pubDate.toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article data-pagefind-body>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.pubDate.toISOString()}>{t('post.publishedOn')} {pub}</time>
    </div>
    {
      post.data.tags.length > 0 && (
        <div style="margin:0.6rem 0 1.5rem">
          {post.data.tags.map((tag) => (
            <a class="tag-pill" href={localizedPath(`/tags/${tag}`, lang)}>
              #{tag}
            </a>
          ))}
        </div>
      )
    }
    <slot />
  </article>

  <hr />
  <p><a href={localizedPath('/', lang)}>{t('post.backToHome')}</a></p>

  <h2>{t('post.comments')}</h2>
  <Comments lang={lang} />
</BaseLayout>
